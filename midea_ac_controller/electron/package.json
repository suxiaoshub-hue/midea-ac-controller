{
  "name": "midea-ac-controller",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.codex.mideaaccontroller",
    "productName": "美的美居多设备控制端",
    "files": [
      "main.js",
      "preload.js",
      "build/**/*",
      "backend/**/*",
      "web/**/*"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "portable"
    }
  }
}
